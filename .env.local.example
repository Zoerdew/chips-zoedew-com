# ---- Airtable ----
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appGtVc9Qki1s4EQc

# Airtable table IDs (locked at build time from the live schema)
AIRTABLE_BET_PARTICIPANTS_TABLE_ID=tblZq1aMffafqSq6P
AIRTABLE_CHIPS_TABLE_ID=tbltaGdpHGYOkeTDB
AIRTABLE_SCRATCH_CARDS_TABLE_ID=tblrszv1OYydoJ95g
AIRTABLE_REPS_TABLE_ID=tblJ31EKgvQhHGDaJ

# ---- Resend (magic link email) ----
# Create a key at https://resend.com/api-keys. Never commit the real value.
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX
# The verified sending address. Must be on a domain verified in Resend.
RESEND_FROM_EMAIL=bet@zoedew.com
# The from-name shown in the recipient's inbox.
RESEND_FROM_NAME=The 100 Minute Bet
# Where replies go when someone hits reply on a portal email.
RESEND_REPLY_TO=zoe@zoedew.com

# ---- Auth ----
# Signs the session cookie. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-64-char-hex-string

# ---- Bet timing (ISO 8601 with UK offset) ----
# Bet opens, logging closes, party room opens, fruit machine unlocks.
# Shift these to soft-launch early or extend without a code change.
# UK is +01:00 in June (BST).
# NEXT_PUBLIC_ prefix so the live countdown timer can read them in the browser.
# Public landing-page reveal. Before this date, chips.zoedew.com shows a
# casino-sign holding page and /api/register returns 503.
NEXT_PUBLIC_LANDING_OPENS_AT=2026-06-08T00:00:00+01:00
NEXT_PUBLIC_BET_OPENS_AT=2026-06-22T00:00:00+01:00
NEXT_PUBLIC_LOGGING_CLOSES_AT=2026-06-28T23:59:59+01:00
# The party room (Meet link + cart) appears at this time, a little before
# the machine unlocks so people can arrive into the call.
NEXT_PUBLIC_PARTY_OPENS_AT=2026-06-29T18:45:00+01:00
NEXT_PUBLIC_FRUIT_MACHINE_UNLOCKS_AT=2026-06-29T19:00:00+01:00

# ---- Casino shop ----
# The shop opens only when BOTH are satisfied:
#   1. SHOP_OPEN is set to exactly "true" (your "products are ready" switch)
#   2. the current time is past SHOP_OPENS_AT
# Set SHOP_OPEN=true any time during the week once your products are sorted;
# the shop will then open itself at SHOP_OPENS_AT. Leave it false to keep the
# shop shut even after the timestamp passes.
NEXT_PUBLIC_SHOP_OPEN=false
NEXT_PUBLIC_SHOP_OPENS_AT=2026-06-29T19:00:00+01:00

# ---- Party ----
# The Google Meet link for the 7pm 29 June casino party.
# Shown on the Casino page once the party time is reached.
NEXT_PUBLIC_PARTY_MEET_URL=https://meet.google.com/gsp-eysd-uys
# The 100 Reps Club cart link, shown at the party.
NEXT_PUBLIC_CART_URL=https://zoedew.com/100-reps-club

# ---- Early access (100 Reps Club) ----
# Members get a secret URL at /early. They enter this password to unlock
# the registration form, which then bypasses the 8 June gate.
# Set both vars to the same value. They must match exactly.
#   - NEXT_PUBLIC_ is read by the browser to compare typed input.
#   - The non-prefixed one is checked server-side in /api/register.
NEXT_PUBLIC_EARLY_ACCESS_PASSWORD=reps2026
EARLY_ACCESS_PASSWORD=reps2026

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://chips.zoedew.com
